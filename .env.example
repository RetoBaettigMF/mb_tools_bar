# OpenClaw Toolbox Konfiguration
# Kopiere diese Datei nach .env und fülle die Werte aus

# ─── Cudos Controlling CLI ─────────────────────────────────────────────────────
MBTOOLS_API_KEY=your-api-key-here

# ─── OpenRouter (AI-basierte Inhaltsbereinigung) ───────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...

# ─── Google AI Search ──────────────────────────────────────────────────────────
GOOGLE_API_KEY=AIza...

# ─── Moneyhouse Scraper ────────────────────────────────────────────────────────
MONEYHOUSE_EMAIL=your@email.ch
MONEYHOUSE_PASSWORD=your-password

# ─── Gmail Trigger ─────────────────────────────────────────────────────────────
# Gmail Zugangsdaten (App-Passwort, nicht normales Passwort!)
# Erstellen unter: Google Account → Sicherheit → 2-Schritt-Verifizierung → App-Passwörter
GMAIL_EMAIL=bar.ai.bot@cudos.ch
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# IMAP Server (normalerweise nicht ändern)
GMAIL_IMAP_SERVER=imap.gmail.com

# OpenClaw Session (wohin die Benachrichtigungen gehen)
OPENCLAW_SESSION=main

# Zu überwachende Labels (komma-getrennt)
GMAIL_LABELS=INBOX

# Check Interval in Sekunden (für Reconnects)
CHECK_INTERVAL=60

# IDLE Timeout in Sekunden (Gmail erlaubt max ~29 Minuten)
IDLE_TIMEOUT=600

# Datei für bereits verarbeitete Message-IDs
PROCESSED_IDS_FILE=/tmp/gmail_trigger_processed.json
