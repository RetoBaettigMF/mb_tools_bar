#!/usr/bin/env python3
"""
google-ai-search - Kommandozeilen-Tool für Google Search mit echten Quellen-URLs

Nutzt Google Custom Search API für echte Suchergebnisse + Gemini API für Zusammenfassung.
"""

import argparse
import sys
import json
import os
import re
from pathlib import Path

# Optional: requests verwenden wenn verfügbar, sonst urllib
try:
    import requests
    HAS_REQUESTS = True
except ImportError:
    HAS_REQUESTS = False
    import urllib.request
    import urllib.error
    import urllib.parse
    import ssl


# API Konfiguration
GEMINI_API_BASE = "https://generativelanguage.googleapis.com/v1beta"
CUSTOM_SEARCH_API_BASE = "https://www.googleapis.com/customsearch/v1"
DEFAULT_MODEL = "gemini-2.5-flash"


class Colors:
    """ANSI Farbcodes für Terminal-Output"""
    RED = '\033[91m'
    GREEN = '\033[92m'
    YELLOW = '\033[93m'
    BLUE = '\033[94m'
    CYAN = '\033[96m'
    BOLD = '\033[1m'
    RESET = '\033[0m'


def load_config():
    """Lädt Konfiguration aus config.json im Tool-Verzeichnis"""
    config_path = Path(__file__).parent / "config.json"
    if config_path.exists():
        try:
            with open(config_path) as f:
                return json.load(f)
        except json.JSONDecodeError as e:
            print_error(f"Config-Datei ist kein gültiges JSON: {e}")
        except Exception as e:
            print_error(f"Fehler beim Laden der Config: {e}")
    return {}


def get_api_key():
    """Holt API Key aus Umgebungsvariable oder Config-Datei"""
    # Priorität 1: Umgebungsvariable
    env_key = os.environ.get("GOOGLE_API_KEY") or os.environ.get("GEMINI_API_KEY")
    if env_key:
        return env_key
    
    # Priorität 2: Config-Datei
    config = load_config()
    return config.get("google_api_key") or config.get("gemini_api_key")


def get_cse_id():
    """Holt Custom Search Engine ID aus Config"""
    # Priorität 1: Umgebungsvariable
    env_cse = os.environ.get("GOOGLE_CSE_ID")
    if env_cse:
        return env_cse
    
    # Priorität 2: Config-Datei
    config = load_config()
    return config.get("google_cse_id")


def print_error(msg):
    """Printet eine Fehlermeldung in Rot"""
    print(f"{Colors.RED}{Colors.BOLD}❌ Fehler:{Colors.RESET} {Colors.RED}{msg}{Colors.RESET}", file=sys.stderr)


def print_warning(msg):
    """Printet eine Warnung in Gelb"""
    print(f"{Colors.YELLOW}⚠️  {msg}{Colors.RESET}", file=sys.stderr)


def print_success(msg):
    """Printet eine Erfolgsmeldung in Grün"""
    print(f"{Colors.GREEN}✅ {msg}{Colors.RESET}")


def print_info(msg):
    """Printet eine Info in Cyan"""
    print(f"{Colors.CYAN}ℹ️  {msg}{Colors.RESET}")


def validate_api_key(api_key):
    """Prüft ob der API-Key gültig aussieht"""
    if not api_key:
        return False, "Kein API Key gefunden"
    
    # Google API Keys sind typischerweise 39 Zeichen lang und starten mit "AIza..."
    if len(api_key) < 10:
        return False, "API Key sieht zu kurz aus"
    
    if not api_key.startswith("AIza"):
        print_warning("API Key startet nicht mit 'AIza' - typischerweise beginnen Google API Keys damit")
    
    return True, None


def google_custom_search(query, api_key, cse_id, num_results=5):
    """
    Führt eine Google Custom Search durch und gibt echte Ergebnisse mit URLs zurück.
    
    Args:
        query: Suchanfrage
        api_key: Google API Key
        cse_id: Custom Search Engine ID
        num_results: Anzahl Ergebnisse (max 10)
    
    Returns:
        Liste von Dicts mit title, link, snippet, displayLink
    """
    url = f"{CUSTOM_SEARCH_API_BASE}"
    
    params = {
        "key": api_key,
        "cx": cse_id,
        "q": query,
        "num": min(num_results, 10),
        "lr": "lang_de",  # Deutsche Sprache bevorzugen
        "gl": "ch",       # Schweizer Region
        "dateRestrict": "m1"  # Letzter Monat für aktuelle Ergebnisse
    }
    
    if HAS_REQUESTS:
        response = requests.get(url, params=params, timeout=15)
        response.raise_for_status()
        data = response.json()
    else:
        # Fallback mit urllib
        query_string = urllib.parse.urlencode(params)
        full_url = f"{url}?{query_string}"
        
        request = urllib.request.Request(full_url)
        with urllib.request.urlopen(request, timeout=15) as response:
            data = json.loads(response.read().decode('utf-8'))
    
    # Ergebnisse extrahieren
    items = data.get("items", [])
    results = []
    
    for item in items:
        results.append({
            "title": item.get("title", "Unbekannt"),
            "link": item.get("link", ""),
            "snippet": item.get("snippet", ""),
            "displayLink": item.get("displayLink", ""),
            "formattedUrl": item.get("formattedUrl", "")
        })
    
    return results


def summarize_with_gemini(query, search_results, api_key, model=None, timeout=30):
    """
    Nutzt Gemini API um Suchergebnisse zusammenzufassen.
    
    Args:
        query: Original Suchanfrage
        search_results: Liste der Suchergebnisse
        api_key: Google API Key
        model: Gemini Modell
        timeout: Timeout in Sekunden
    
    Returns:
        Zusammengefasster Text
    """
    model = model or DEFAULT_MODEL
    
    # Erstelle Kontext aus den Suchergebnissen
    context = "\n\n".join([
        f"Quelle {i+1}:\nTitel: {r['title']}\nURL: {r['link']}\nInhalt: {r['snippet']}"
        for i, r in enumerate(search_results[:5])
    ])
    
    # Prompt für Gemini
    prompt = f"""Basierend auf folgenden aktuellen Suchergebnissen, beantworte diese Frage:

FRAGE: {query}

SUCHERGEBNISSE:
{context}

WICHTIG:
- Beantworte die Frage prägnant und vollständig
- Nutze die Informationen aus den Suchergebnissen
- Antworte auf Deutsch
- Erwähne keine Quellen-Nummern im Text"""
    
    url = f"{GEMINI_API_BASE}/models/{model}:generateContent?key={api_key}"
    
    data = {
        "contents": [{
            "parts": [{"text": prompt}]
        }],
        "generationConfig": {
            "temperature": 0.3,
            "maxOutputTokens": 2048
        }
    }
    
    headers = {"Content-Type": "application/json"}
    
    if HAS_REQUESTS:
        response = requests.post(url, json=data, headers=headers, timeout=timeout)
        response.raise_for_status()
        result = response.json()
    else:
        # Fallback mit urllib
        request = urllib.request.Request(
            url,
            data=json.dumps(data).encode('utf-8'),
            headers=headers,
            method='POST'
        )
        with urllib.request.urlopen(request, timeout=timeout) as response:
            result = json.loads(response.read().decode('utf-8'))
    
    # Antwort extrahieren
    candidates = result.get("candidates", [])
    if candidates:
        content = candidates[0].get("content", {})
        parts = content.get("parts", [])
        if parts:
            return parts[0].get("text", "")
    
    return "Keine Zusammenfassung verfügbar."


def search(query, model=None, json_output=False, raw=False, timeout=30, show_tools=False, num_results=5):
    """
    Führt eine Google Search durch und gibt Ergebnisse mit echten URLs zurück.
    
    Args:
        query: Die Suchanfrage
        model: Optional ein bestimmtes Gemini-Modell
        json_output: JSON-Format ausgeben
        raw: Rohe Ausgabe ohne Formatierung
        timeout: Timeout in Sekunden
        show_tools: Zeige verwendete Tools an
        num_results: Anzahl Suchergebnisse
    """
    # API Key validieren
    api_key = get_api_key()
    is_valid, error_msg = validate_api_key(api_key)
    
    if not is_valid:
        print_error(error_msg)
        print(f"\n{Colors.BOLD}So kannst du einen API Key hinzufügen:{Colors.RESET}")
        print(f"  1. Umgebungsvariable: {Colors.CYAN}export GOOGLE_API_KEY='dein-key'{Colors.RESET}")
        print(f"  2. Config-Datei: {Colors.CYAN}{Path(__file__).parent}/config.json{Colors.RESET}")
        print(f"\n{Colors.BOLD}API Key erstellen:{Colors.RESET}")
        print(f"  → https://console.cloud.google.com/apis/credentials")
        sys.exit(1)
    
    # CSE ID prüfen
    cse_id = get_cse_id()
    if not cse_id:
        print_error("Keine Custom Search Engine ID (CSE ID) gefunden")
        print(f"\n{Colors.BOLD}So richtest du die CSE ID ein:{Colors.RESET}")
        print(f"  1. Erstelle eine Custom Search Engine: https://programmablesearchengine.google.com/")
        print(f"  2. Füge die CSE ID hinzu zu:")
        print(f"     - Umgebungsvariable: {Colors.CYAN}export GOOGLE_CSE_ID='deine-cse-id'{Colors.RESET}")
        print(f"     - Oder config.json: {Colors.CYAN}{Path(__file__).parent}/config.json{Colors.RESET}")
        sys.exit(1)
    
    try:
        if not json_output and not raw:
            print_info(f"Suche mit Google Custom Search nach: {query}")
        
        # 1. Google Custom Search durchführen
        search_results = google_custom_search(query, api_key, cse_id, num_results)
        
        if not search_results:
            print_error("Keine Suchergebnisse gefunden")
            sys.exit(1)
        
        # 2. Mit Gemini zusammenfassen
        if not json_output and not raw:
            print_info(f"Erstelle Zusammenfassung mit Gemini ({model or DEFAULT_MODEL})...")
        
        summary = summarize_with_gemini(query, search_results, api_key, model, timeout)
        
        # Verwendete Tools anzeigen
        if show_tools and not json_output and not raw:
            print(f"\n{Colors.CYAN}🔧 Verwendete Tools:{Colors.RESET}")
            print(f"  • Google Custom Search API")
            print(f"  • Gemini API ({model or DEFAULT_MODEL})")
            print(f"  • {len(search_results)} Quellen gefunden")
            print()
        
        # Output formatieren
        if json_output:
            output = {
                "query": query,
                "model": model or DEFAULT_MODEL,
                "response": summary,
                "sources": [
                    {
                        "title": r["title"],
                        "uri": r["link"],
                        "snippet": r["snippet"],
                        "domain": r["displayLink"]
                    }
                    for r in search_results
                ]
            }
            print(json.dumps(output, indent=2, ensure_ascii=False))
        elif raw:
            print(summary)
            print()
            for r in search_results:
                print(f"{r['title']}")
                print(f"{r['link']}")
                print(f"{r['snippet']}")
                print()
        else:
            print(f"\n{summary}\n")
            
            # Quellen anzeigen
            print(f"{Colors.CYAN}📚 Quellen:{Colors.RESET}")
            for i, result in enumerate(search_results[:5], 1):
                title = result["title"]
                link = result["link"]
                domain = result["displayLink"]
                
                # URL kürzen wenn zu lang
                display_link = link if len(link) < 70 else link[:67] + "..."
                print(f"  {i}. {Colors.BOLD}{title}{Colors.RESET}")
                print(f"     {Colors.BLUE}{display_link}{Colors.RESET}")
                if domain:
                    print(f"     ({domain})")
            print()
                
    except PermissionError as e:
        print_error(str(e))
        print(f"\n{Colors.BOLD}Lösung:{Colors.RESET}")
        print("  1. Prüfe ob der API Key gültig ist: https://console.cloud.google.com/apis/credentials")
        print("  2. Aktiviere die Custom Search API: https://console.cloud.google.com/apis/library/customsearch.googleapis.com")
        print("  3. Prüfe ob das Projekt Billing hat")
        sys.exit(1)
        
    except ConnectionError as e:
        print_error(str(e))
        print(f"\n{Colors.BOLD}Mögliche Ursachen:{Colors.RESET}")
        print("  • Keine Internetverbindung")
        print("  • Firewall/Proxy blockiert den Zugriff")
        sys.exit(1)
        
    except TimeoutError as e:
        print_error(str(e))
        print(f"\n{Colors.BOLD}Tipps:{Colors.RESET}")
        print(f"  • Erhöhe das Timeout: --timeout 60")
        sys.exit(1)
        
    except Exception as e:
        print_error(f"Unerwarteter Fehler: {e}")
        if os.environ.get("DEBUG"):
            import traceback
            traceback.print_exc()
        sys.exit(1)


def interactive_mode():
    """Interaktiver Modus für wiederholte Abfragen"""
    print(f"{Colors.CYAN}{Colors.BOLD}🔍 Google AI Search - Interaktiver Modus{Colors.RESET}")
    print("Nutzt Google Custom Search API + Gemini für echte Quellen-URLs\n")
    print("Tippe 'exit' oder 'quit' zum Beenden\n")
    
    # API Key prüfen
    api_key = get_api_key()
    if not api_key:
        print_error("Kein API Key gefunden. Bitte zuerst einrichten.")
        sys.exit(1)
    
    # CSE ID prüfen
    cse_id = get_cse_id()
    if not cse_id:
        print_error("Keine CSE ID gefunden. Bitte zuerst einrichten.")
        sys.exit(1)
    
    print_success("API Key und CSE ID gefunden. Bereit für Anfragen.\n")
    
    while True:
        try:
            query = input(f"{Colors.BOLD}Suche >{Colors.RESET} ").strip()
            
            if query.lower() in ("exit", "quit", "q"):
                print(f"\n{Colors.GREEN}👋 Auf Wiedersehen!{Colors.RESET}")
                break
            
            if not query:
                continue
            
            print()
            search(query, show_tools=True)
            
        except KeyboardInterrupt:
            print(f"\n\n{Colors.GREEN}👋 Auf Wiedersehen!{Colors.RESET}")
            break
        except EOFError:
            break


def main():
    parser = argparse.ArgumentParser(
        description="Google AI Search mit echten Quellen-URLs via Custom Search API",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=f"""
{Colors.BOLD}Beispiele:{Colors.RESET}
  google-ai-search "Aktueller Stand von Fusion Energy"
  google-ai-search --json "Wetter in Zürich morgen"
  google-ai-search --num-results 10 "Python 3.12 neue Features"
  google-ai-search -i                    # Interaktiver Modus

{Colors.BOLD}Einrichtung:{Colors.RESET}
  1. Erstelle einen API Key: https://console.cloud.google.com/apis/credentials
  2. Aktiviere Custom Search API
  3. Erstelle eine CSE: https://programmablesearchengine.google.com/
  4. Füge API Key und CSE ID zu config.json oder Umgebungsvariablen hinzu

{Colors.BOLD}Umgebungsvariablen:{Colors.RESET}
  GOOGLE_API_KEY oder GEMINI_API_KEY
  GOOGLE_CSE_ID
        """
    )
    
    parser.add_argument(
        "query",
        nargs="?",
        help="Die Suchanfrage (optional im interaktiven Modus)"
    )
    
    parser.add_argument(
        "-i", "--interactive",
        action="store_true",
        help="Interaktiver Modus für wiederholte Abfragen"
    )
    
    parser.add_argument(
        "-m", "--model",
        default=None,
        help=f"Gemini-Modell für Zusammenfassung (default: {DEFAULT_MODEL})"
    )
    
    parser.add_argument(
        "-j", "--json",
        action="store_true",
        help="Ausgabe als JSON"
    )
    
    parser.add_argument(
        "-r", "--raw",
        action="store_true",
        help="Rohe Ausgabe ohne Formatierung"
    )
    
    parser.add_argument(
        "-t", "--timeout",
        type=int,
        default=30,
        help="Timeout in Sekunden (default: 30)"
    )
    
    parser.add_argument(
        "-n", "--num-results",
        type=int,
        default=5,
        help="Anzahl Suchergebnisse (default: 5, max: 10)"
    )
    
    parser.add_argument(
        "--show-tools",
        action="store_true",
        help="Zeige verwendete Tools an"
    )
    
    parser.add_argument(
        "--version",
        action="version",
        version="%(prog)s 3.0.0"
    )
    
    args = parser.parse_args()
    
    # Interaktiver Modus
    if args.interactive:
        interactive_mode()
        return
    
    # Query muss angegeben sein
    if not args.query:
        parser.print_help()
        sys.exit(1)
    
    # Normale Suche
    search(
        args.query, 
        args.model, 
        args.json, 
        args.raw, 
        args.timeout,
        args.show_tools,
        args.num_results
    )


if __name__ == "__main__":
    main()
