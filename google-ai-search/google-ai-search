#!/usr/bin/env python3
"""
google-ai-search - Kommandozeilen-Tool für Google Search mit AI-Zusammenfassung

Nutzt Gemini API mit Google Search Grounding für echte Suchergebnisse + AI-Antworten.
"""

import argparse
import sys
import json
import os
import urllib.request
from pathlib import Path

try:
    from google import genai
    from google.genai import types
    HAS_GENAI = True
except ImportError:
    HAS_GENAI = False

# .env aus dem Repo-Root laden
try:
    from dotenv import load_dotenv
    load_dotenv(Path(__file__).parent.parent / ".env")
except ImportError:
    pass


DEFAULT_MODEL = "gemini-2.5-flash"


class Colors:
    RED = '\033[91m'
    GREEN = '\033[92m'
    YELLOW = '\033[93m'
    BLUE = '\033[94m'
    CYAN = '\033[96m'
    BOLD = '\033[1m'
    RESET = '\033[0m'


def load_config():
    config_path = Path(__file__).parent / "config.json"
    if config_path.exists():
        try:
            with open(config_path) as f:
                return json.load(f)
        except Exception as e:
            print_error(f"Fehler beim Laden der Config: {e}")
    return {}


def get_api_key():
    env_key = os.environ.get("GOOGLE_API_KEY") or os.environ.get("GEMINI_API_KEY")
    if env_key:
        return env_key
    config = load_config()
    return config.get("google_api_key") or config.get("gemini_api_key")


def print_error(msg):
    print(f"{Colors.RED}{Colors.BOLD}❌ Fehler:{Colors.RESET} {Colors.RED}{msg}{Colors.RESET}", file=sys.stderr)


def print_warning(msg):
    print(f"{Colors.YELLOW}⚠️  {msg}{Colors.RESET}", file=sys.stderr)


def print_info(msg):
    print(f"{Colors.CYAN}ℹ️  {msg}{Colors.RESET}", file=sys.stderr)


def resolve_redirect(uri):
    """Folgt einem Redirect und gibt die finale URL zurück."""
    if "vertexaisearch.cloud.google.com" not in uri:
        return uri
    try:
        req = urllib.request.Request(uri, method="HEAD", headers={"User-Agent": "Mozilla/5.0"})
        with urllib.request.urlopen(req, timeout=5) as resp:
            return resp.url
    except Exception:
        try:
            req = urllib.request.Request(uri, headers={"User-Agent": "Mozilla/5.0"})
            with urllib.request.urlopen(req, timeout=5) as resp:
                return resp.url
        except Exception:
            return uri


def add_citations(response, chunks):
    """Fügt Inline-Zitierungen in den Text ein."""
    text = response.text
    supports = response.candidates[0].grounding_metadata.grounding_supports

    sorted_supports = sorted(supports, key=lambda s: s.segment.end_index, reverse=True)

    for support in sorted_supports:
        end_index = support.segment.end_index
        if support.grounding_chunk_indices:
            citation_links = []
            for i in support.grounding_chunk_indices:
                if i < len(chunks):
                    uri = chunks[i].web.uri
                    citation_links.append(f"[{i + 1}]({uri})")
            citation_string = "".join(citation_links)
            text = text[:end_index] + citation_string + text[end_index:]

    return text


def search(query, model=None, json_output=False, raw=False, timeout=30):
    if not HAS_GENAI:
        print_error("google-genai nicht installiert. Bitte: pip install google-genai")
        sys.exit(1)

    api_key = get_api_key()
    if not api_key:
        print_error("Kein API Key gefunden.")
        print(f"\n{Colors.BOLD}API Key hinzufügen:{Colors.RESET}", file=sys.stderr)
        print(f"  1. Umgebungsvariable: {Colors.CYAN}export GOOGLE_API_KEY='dein-key'{Colors.RESET}", file=sys.stderr)
        print(f"  2. Config-Datei: {Colors.CYAN}{Path(__file__).parent}/config.json{Colors.RESET}", file=sys.stderr)
        sys.exit(1)

    model = model or DEFAULT_MODEL

    if not json_output and not raw:
        print_info(f"Suche nach: {query}")

    try:
        client = genai.Client(api_key=api_key)

        grounding_tool = types.Tool(google_search=types.GoogleSearch())
        config = types.GenerateContentConfig(
            tools=[grounding_tool],
            temperature=0.3,
        )

        response = client.models.generate_content(
            model=model,
            contents=query,
            config=config,
        )

        # Quellen aus Grounding Metadata extrahieren
        sources = []
        chunks = []
        candidate = response.candidates[0] if response.candidates else None
        if candidate and candidate.grounding_metadata:
            meta = candidate.grounding_metadata
            chunks = meta.grounding_chunks or []
            seen = set()
            for chunk in chunks:
                if chunk.web and chunk.web.uri not in seen:
                    seen.add(chunk.web.uri)
                    resolved_uri = resolve_redirect(chunk.web.uri)
                    sources.append({
                        "title": chunk.web.title or "",
                        "uri": resolved_uri,
                        "original_uri": chunk.web.uri,
                    })

        # Chunks mit resolvierten URIs für Inline-Zitierungen
        resolved_chunks = []
        for chunk in chunks:
            if chunk.web:
                resolved_uri = next(
                    (s["uri"] for s in sources if s["original_uri"] == chunk.web.uri),
                    chunk.web.uri
                )
                # Wrapper-Objekt simulieren
                class ResolvedChunk:
                    class web:
                        pass
                rc = ResolvedChunk()
                rc.web = type("web", (), {"uri": resolved_uri, "title": chunk.web.title})()
                resolved_chunks.append(rc)
            else:
                resolved_chunks.append(chunk)

        # Text mit Inline-Zitierungen
        try:
            summary = add_citations(response, resolved_chunks)
        except Exception:
            summary = response.text

        # Output
        if json_output:
            output = {
                "query": query,
                "model": model,
                "response": summary,
                "sources": [{"title": s["title"], "uri": s["uri"]} for s in sources],
            }
            print(json.dumps(output, indent=2, ensure_ascii=False))
        elif raw:
            print(summary)
            print()
            for s in sources:
                print(s["title"])
                print(s["uri"])
                print()
        else:
            print(f"\n{summary}\n")
            if sources:
                print(f"{Colors.CYAN}📚 Quellen:{Colors.RESET}")
                for i, s in enumerate(sources[:8], 1):
                    title = s["title"]
                    uri = s["uri"]
                    display = uri if len(uri) < 70 else uri[:67] + "..."
                    print(f"  {i}. {Colors.BOLD}{title}{Colors.RESET}")
                    print(f"     {Colors.BLUE}{display}{Colors.RESET}")
            print()

    except Exception as e:
        print_error(f"Fehler: {e}")
        if os.environ.get("DEBUG"):
            import traceback
            traceback.print_exc()
        sys.exit(1)


def interactive_mode():
    print(f"{Colors.CYAN}{Colors.BOLD}🔍 Google AI Search - Interaktiver Modus{Colors.RESET}")
    print("Tippe 'exit' oder 'quit' zum Beenden\n")

    api_key = get_api_key()
    if not api_key:
        print_error("Kein API Key gefunden. Bitte zuerst einrichten.")
        sys.exit(1)

    while True:
        try:
            query = input(f"{Colors.BOLD}Suche >{Colors.RESET} ").strip()
            if query.lower() in ("exit", "quit", "q"):
                print(f"\n{Colors.GREEN}👋 Auf Wiedersehen!{Colors.RESET}")
                break
            if not query:
                continue
            print()
            search(query)
        except KeyboardInterrupt:
            print(f"\n\n{Colors.GREEN}👋 Auf Wiedersehen!{Colors.RESET}")
            break
        except EOFError:
            break


def main():
    parser = argparse.ArgumentParser(
        description="Google AI Search via Gemini mit Google Search Grounding",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=f"""
{Colors.BOLD}Beispiele:{Colors.RESET}
  google-ai-search "Aktueller Stand von Fusion Energy"
  google-ai-search --json "Wetter in Zürich morgen"
  google-ai-search -i                    # Interaktiver Modus

{Colors.BOLD}Einrichtung:{Colors.RESET}
  1. Erstelle einen API Key: https://console.cloud.google.com/apis/credentials
  2. Aktiviere die Gemini API
  3. Füge API Key zu config.json oder Umgebungsvariable hinzu

{Colors.BOLD}Umgebungsvariablen:{Colors.RESET}
  GOOGLE_API_KEY oder GEMINI_API_KEY
        """
    )

    parser.add_argument("query", nargs="?", help="Die Suchanfrage")
    parser.add_argument("-i", "--interactive", action="store_true", help="Interaktiver Modus")
    parser.add_argument("-m", "--model", default=None, help=f"Gemini-Modell (default: {DEFAULT_MODEL})")
    parser.add_argument("-j", "--json", action="store_true", help="Ausgabe als JSON")
    parser.add_argument("-r", "--raw", action="store_true", help="Rohe Ausgabe")
    parser.add_argument("-t", "--timeout", type=int, default=30, help="Timeout in Sekunden")
    parser.add_argument("--version", action="version", version="%(prog)s 4.0.0")

    args = parser.parse_args()

    if args.interactive:
        interactive_mode()
        return

    if not args.query:
        parser.print_help()
        sys.exit(1)

    search(args.query, args.model, args.json, args.raw, args.timeout)


if __name__ == "__main__":
    main()
