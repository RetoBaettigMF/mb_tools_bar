#!/usr/bin/env python3
"""
morticia-podcast - Generiert einen täglichen News-Podcast (15-20 Min.)
Mit detaillierten Zusammenfassungen, Duplikat-Erkennung und bereinigtem TTS.
"""

import argparse
import json
import os
import re
import subprocess
import sys
import tempfile
import hashlib
from datetime import datetime
from pathlib import Path
from typing import List, Dict, Tuple, Optional

# Konfiguration
NZZ_READER = "~/Development/mb_tools_bar/nzz-reader/nzz-reader"
GOOGLE_AI_SEARCH = "~/Development/mb_tools_bar/google-ai-search/google-ai-search"
MORTICIA_PUBLISH = "~/Development/mb_tools_bar/morticia-publish/morticia-publish"
BASE_URL = "https://baettig.org/morticia"

class Article:
    """Repräsentiert einen Artikel mit allen Metadaten."""
    def __init__(self, title: str, category: str, source: str = "", url: str = ""):
        self.title = title
        self.category = category
        self.source = source
        self.url = url
        self.summary = ""
        self.score = 0
        self.id = hashlib.md5(title.encode()).hexdigest()[:8]

class PodcastGenerator:
    def __init__(self, date: str = None, publish: bool = False):
        self.date = date or datetime.now().strftime("%Y-%m-%d")
        self.publish = publish
        self.output_dir = Path(tempfile.gettempdir()) / "morticia-podcast"
        self.output_dir.mkdir(exist_ok=True)
        
        self.all_articles: List[Article] = []
        self.selected_articles: List[Article] = []
        self.sources = []
        
    def run_command(self, cmd: str, capture_output: bool = True, timeout: int = 60) -> Tuple[bool, str, str]:
        try:
            result = subprocess.run(cmd, shell=True, capture_output=capture_output, text=True, timeout=timeout)
            return result.returncode == 0, result.stdout, result.stderr
        except subprocess.TimeoutExpired:
            return False, "", "Timeout"
        except Exception as e:
            return False, "", str(e)
    
    def get_nzz_articles(self) -> List[Article]:
        print("📰 Lade NZZ-Artikel...")
        success, stdout, stderr = self.run_command(f"{NZZ_READER} --json 2>/dev/null || {NZZ_READER}")
        
        if not success:
            return []
        
        articles = []
        try:
            data = json.loads(stdout)
            if isinstance(data, list):
                for item in data:
                    articles.append(Article(title=item.get("title", ""), category="unknown", source="NZZ", url=item.get("url", "")))
            elif isinstance(data, dict) and "articles" in data:
                for item in data["articles"]:
                    articles.append(Article(title=item.get("title", ""), category="unknown", source="NZZ", url=item.get("url", "")))
        except json.JSONDecodeError:
            lines = stdout.strip().split('\n')
            for line in lines:
                if line.strip() and not line.startswith('-'):
                    articles.append(Article(title=line.strip(), category="unknown", source="NZZ"))
        
        print(f"   {len(articles)} geladen")
        return articles
    
    def search_category(self, category: str, query: str) -> List[Article]:
        print(f"🔍 Suche {category}...", end=" ")
        
        cmd = f'{GOOGLE_AI_SEARCH} --json "{query}" 2>/dev/null'
        success, stdout, stderr = self.run_command(cmd, timeout=60)
        
        if not success:
            print("✗")
            return []
        
        articles = []
        try:
            result = json.loads(stdout)
            response = result.get("response", "")
            sources = result.get("sources", [])
            
            for src in sources[:5]:
                if src not in self.sources:
                    self.sources.append(src)
            
            lines = response.split('\n')
            for line in lines:
                line = line.strip()
                if line and len(line) > 20 and len(line) < 300:
                    if not self._is_excluded_topic(line) and not line.startswith('#'):
                        source = sources[0]["title"] if sources else "Web"
                        url = sources[0].get("uri", "") if sources else ""
                        articles.append(Article(title=line[:250], category=category, source=source, url=url))
            
            print(f"{len(articles)}")
            return articles
            
        except json.JSONDecodeError:
            print("✗")
            return []
    
    def _is_excluded_topic(self, text: str) -> bool:
        text_lower = text.lower()
        sport_keywords = ['fussball', 'bundesliga', 'champions league', 'super league', 'wm ', 'em ', 'olympia', 'sport', 'tor ', 'sieg', 'meister', 'pokal', 'tennis', 'ski', 'formel 1', 'f1 ', 'grand prix', 'fc ', 'gc ', 'yb ', 'cup', 'tournament', 'match', 'spiel']
        celeb_keywords = ['promi', 'prominent', 'schauspieler', 'sänger', 'musiker', 'könig', 'königin', 'prinz', 'prinzessin', 'royal', 'hollywood', 'oscar', 'grammy', 'filmstar', 'star ', 'vip', 'diva']
        return any(kw in text_lower for kw in sport_keywords + celeb_keywords)
    
    def _is_error_or_hint(self, text: str) -> bool:
        """Prüft ob der Text eine Fehlermeldung oder Hinweis ist."""
        text_lower = text.lower()
        error_patterns = [
            'ungültig', 'fehler', 'error', 'invalid', 'argument',
            'verwende', 'help', 'hilfe', '--', '***', '❌', '💡',
            'achtung', 'warnung', 'warning', 'nicht gefunden',
            'could not', 'unable to', 'failed'
        ]
        return any(pat in text_lower for pat in error_patterns)
    
    def _remove_duplicates(self, articles: List[Article]) -> List[Article]:
        """Entfernt Duplikate basierend auf ähnlichen Titeln."""
        unique = []
        seen_hashes = set()
        
        for art in articles:
            # Erstelle einen normalisierten Hash
            normalized = art.title.lower()
            normalized = re.sub(r'[^\w\s]', '', normalized)  # Entferne Satzzeichen
            normalized = re.sub(r'\s+', ' ', normalized).strip()  # Normalisiere Whitespace
            
            # Prüfe auf ähnliche existierende Artikel
            is_duplicate = False
            for existing in unique:
                existing_norm = existing.title.lower()
                existing_norm = re.sub(r'[^\w\s]', '', existing_norm)
                existing_norm = re.sub(r'\s+', ' ', existing_norm).strip()
                
                # Wenn mehr als 70% Übereinstimmung
                if self._similarity(normalized, existing_norm) > 0.7:
                    is_duplicate = True
                    break
            
            if not is_duplicate and not self._is_error_or_hint(art.title):
                unique.append(art)
        
        return unique
    
    def _similarity(self, s1: str, s2: str) -> float:
        """Berechnet ähnlichkeit zwischen zwei Strings (simple Jaccard)."""
        words1 = set(s1.split())
        words2 = set(s2.split())
        if not words1 or not words2:
            return 0.0
        intersection = words1 & words2
        union = words1 | words2
        return len(intersection) / len(union)
    
    def _categorize_article(self, article: Article):
        title_lower = article.title.lower()
        intl_kw = ['usa', 'eu', 'ukraine', 'russland', 'china', 'trump', 'gaza', 'israel', 'iran', 'nato', 'un ', 'uk', 'frankreich', 'deutschland', 'biden', 'putin', 'moskau', 'washington', 'palestin', 'europa', 'asien', 'afrika']
        ch_kw = ['schweiz', 'bundesrat', 'nationalrat', 'bern', 'zürich', 'genf', 'basel', 'svp', 'sp ', 'fdp', 'grüne', 'parlament', 'bundesgericht']
        eco_kw = ['börse', 'aktie', 'inflation', 'ezb', 'snb', 'umsatz', 'gewinn', 'wirtschaft', 'konjunktur', 'handel', 'export', 'import']
        sci_kw = ['forschung', 'studie', 'universität', 'medizin', 'klima', 'wissenschaft', 'forscher', 'entdeckung', 'technologie', 'ki ', 'ai ', 'gen']
        
        if any(kw in title_lower for kw in intl_kw):
            article.category = "international"
        elif any(kw in title_lower for kw in ch_kw):
            article.category = "schweiz"
        elif any(kw in title_lower for kw in eco_kw):
            article.category = "wirtschaft"
        elif any(kw in title_lower for kw in sci_kw):
            article.category = "wissenschaft"
        else:
            article.category = "international"
    
    def _score_article(self, article: Article):
        score = 0
        title_lower = article.title.lower()
        high_impact = ['krieg', 'ukraine', 'gaza', 'trump', 'putin', 'krise', 'anschlag', 'terror', 'bundesrat', 'wahl', ' referendum', 'abstimmung', 'inflation', 'rezession', 'pleite', 'insolvenz']
        medium_impact = ['usa', 'eu', 'china', 'russland', 'verhandlung', 'gipfel', 'gesetz', 'entscheid', 'urteil', 'börse', 'ezb', 'snb']
        
        for kw in high_impact:
            if kw in title_lower:
                score += 10
        for kw in medium_impact:
            if kw in title_lower:
                score += 5
        if len(article.title) > 80:
            score += 3
        if article.source == "NZZ":
            score += 2
        
        article.score = score
        return score
    
    def collect_news(self):
        print("\n📡 Sammle News...\n")
        
        # NZZ Artikel
        nzz_articles = self.get_nzz_articles()
        for art in nzz_articles:
            self._categorize_article(art)
            self._score_article(art)
        self.all_articles.extend(nzz_articles)
        
        # Online-Suche
        today = datetime.now().strftime("%d.%m.%Y")
        queries = [
            ("international", f"top internationale politische nachrichten heute {today} trump ukraine usa"),
            ("schweiz", f"schweiz news politik bundesrat heute {today}"),
            ("wirtschaft", f"wirtschaft börse aktien inflation ezb snb heute {today}"),
            ("wissenschaft", f"wissenschaft forschung medizin klima entdeckung heute {today}"),
        ]
        
        for category, query in queries:
            articles = self.search_category(category, query)
            for art in articles:
                self._score_article(art)
            self.all_articles.extend(articles)
        
        # Entferne Duplikate und Fehler
        self.all_articles = self._remove_duplicates(self.all_articles)
        
        # Sortiere und wähle aus
        self.all_articles.sort(key=lambda x: x.score, reverse=True)
        
        selected = []
        counts = {"international": 0, "schweiz": 0, "wirtschaft": 0, "wissenschaft": 0}
        limits = {"international": 5, "schweiz": 4, "wirtschaft": 3, "wissenschaft": 3}
        
        for art in self.all_articles:
            cat = art.category
            if cat in counts and counts[cat] < limits[cat]:
                selected.append(art)
                counts[cat] += 1
                if len(selected) >= 15:
                    break
        
        self.selected_articles = selected
        
        print(f"\n📊 {len(self.all_articles)} Artikel gesammelt")
        print(f"✅ {len(selected)} ausgewählt")
        for cat, count in counts.items():
            if count > 0:
                print(f"   {cat}: {count}")
    
    def _generate_summary(self, article: Article) -> str:
        print(f"   📝 {article.title[:50]}...", end=" ")
        
        query = f"{article.title} nachrichten details hintergründe"
        cmd = f'{GOOGLE_AI_SEARCH} --json "{query}" 2>/dev/null'
        success, stdout, stderr = self.run_command(cmd, timeout=60)
        
        if not success:
            print("✗")
            return article.title
        
        try:
            result = json.loads(stdout)
            response = result.get("response", "")
            summary = self._clean_summary(response)
            
            if len(summary.split()) < 30 or self._is_error_or_hint(summary):
                summary = article.title
            
            print(f"✓ ({len(summary.split())} Wörter)")
            return summary
            
        except:
            print("✗")
            return article.title
    
    def _clean_summary(self, text: str) -> str:
        """Bereinigt die Summary."""
        # Entferne Markdown
        text = re.sub(r'\*\*', '', text)
        text = re.sub(r'\*', '', text)
        text = re.sub(r'#+\s*', '', text)
        text = re.sub(r'`', '', text)
        text = re.sub(r'\[([^\]]+)\]\([^)]+\)', r'\1', text)
        text = re.sub(r'https?://\S+', '', text)
        text = re.sub(r'^[\s•\-\*]+', '', text, flags=re.MULTILINE)
        
        # Entferne Filler-Text
        fillers = [
            r'^Hier sind die.*?', r'^Aktuelle.*?', r'^Die wichtigsten.*?',
            r'^Dies ist.*?', r'^Es gibt.*?', r'^Zusammenfassung.*?',
        ]
        for filler in fillers:
            text = re.sub(filler, '', text, flags=re.IGNORECASE | re.MULTILINE)
        
        # Entferne Nummerierungen am Anfang
        text = re.sub(r'^\d+\.\s*', '', text, flags=re.MULTILINE)
        
        # Entferne Quellenverweise am Ende
        text = re.sub(r'Quellen?:.*', '', text, flags=re.DOTALL | re.IGNORECASE)
        text = re.sub(r'Sources?:.*', '', text, flags=re.DOTALL | re.IGNORECASE)
        text = re.sub(r'\n\s*\n\s*\n+', '\n\n', text)
        
        return text.strip()
    
    def generate_summaries(self):
        print("\n📖 Recherchiere Details...\n")
        for article in self.selected_articles:
            summary = self._generate_summary(article)
            article.summary = summary
    
    def generate_script(self) -> str:
        """Generiert das TTS-Skript OHNE Quellenangaben."""
        print("\n✍️  Erstelle TTS-Skript...\n")
        
        months = ["", "Januar", "Februar", "März", "April", "Mai", "Juni",
                  "Juli", "August", "September", "Oktober", "November", "Dezember"]
        dt = datetime.strptime(self.date, "%Y-%m-%d")
        date_str = f"{dt.day}. {months[dt.month]} {dt.year}"
        
        by_category = {"international": [], "schweiz": [], "wirtschaft": [], "wissenschaft": []}
        for art in self.selected_articles:
            if art.category in by_category:
                by_category[art.category].append(art)
        
        lines = []
        lines.append(f"News vom {date_str}.")
        
        cat_names = {"international": "International", "schweiz": "Schweiz", "wirtschaft": "Wirtschaft", "wissenschaft": "Wissenschaft"}
        
        for cat_key, cat_name in cat_names.items():
            articles = by_category[cat_key]
            if not articles:
                continue
            
            lines.append("")
            lines.append(f"{cat_name}.")
            
            for art in articles:
                lines.append("")
                clean_summary = self._clean_for_tts(art.summary or art.title)
                # Überspringe leere oder zu kurze Inhalte
                if len(clean_summary.split()) >= 10:
                    lines.append(clean_summary)
        
        script = "\n".join(lines)
        
        # Final: Entferne Wiederholungen im gesamten Script
        script = self._remove_repetitions(script)
        
        return script.strip()
    
    def _remove_repetitions(self, text: str) -> str:
        """Entfernt wiederholte Sätze oder Phrasen."""
        lines = text.split('\n')
        seen = set()
        unique_lines = []
        
        for line in lines:
            # Normalisiere für Vergleich
            normalized = line.lower().strip()
            normalized = re.sub(r'[^\w\s]', '', normalized)
            normalized = re.sub(r'\s+', ' ', normalized)
            
            # Überspringe exakte Duplikate
            if normalized and normalized not in seen:
                seen.add(normalized)
                unique_lines.append(line)
            elif not normalized:  # Leere Zeilen beibehalten für Struktur
                unique_lines.append(line)
        
        return '\n'.join(unique_lines)
    
    def _clean_for_tts(self, text: str) -> str:
        """Finaler Cleanup speziell für TTS - KEINE Quellen!"""
        text = text.replace('*', '').replace('#', '').replace('`', '')
        text = text.replace('|', '').replace('>', '').replace('<', '')
        text = text.replace('_', ' ').replace('~', '').replace('^', '')
        
        # Entferne Klammern aber behalte Inhalt
        text = re.sub(r'\[([^\]]+)\]', r'\1', text)
        text = re.sub(r'\(([^)]+)\)', r'\1', text)
        
        # Entferne URLs und E-Mails
        text = re.sub(r'https?://\S+', '', text)
        text = re.sub(r'\S+@\S+', '', text)
        
        # Entferne Quellenverweise
        text = re.sub(r'–?\s*Quelle:.*', '', text)
        text = re.sub(r'–?\s*Source:.*', '', text)
        text = re.sub(r'\([^)]*quelle[^)]*\)', '', text, flags=re.IGNORECASE)
        
        # Entferne doppelte Leerzeichen
        text = re.sub(r' +', ' ', text)
        
        # Entferne Leerzeilen am Anfang/Ende, behalte Struktur
        lines = [l.strip() for l in text.split('\n')]
        return '\n'.join(lines)
    
    def create_markdown(self, tts_script: str) -> Path:
        """Erstellt die Markdown-Datei MIT Quellen am Ende."""
        date_str = datetime.strptime(self.date, "%Y-%m-%d").strftime("%d.%m.%Y")
        
        md = f"""# Morticia Podcast – {date_str}

🎧 [MP3 anhören](morticia-podcast-{self.date}.mp3)

---

## Skript

"""
        
        # Füge bereinigtes TTS-Skript ein
        md += tts_script
        
        md += "\n\n---\n\n## Artikel im Detail\n\n"
        
        for art in self.selected_articles:
            md += f"**{art.title}**\n\n"
            if art.summary:
                summary_clean = art.summary.replace('*', '')
                md += f"{summary_clean}\n\n"
            if art.source:
                md += f"_Quelle: {art.source}_\n"
            if art.url:
                md += f"_{art.url}_\n"
            md += "\n---\n\n"
        
        md += "## Alle Quellen\n\n"
        if self.sources:
            for i, src in enumerate(self.sources, 1):
                title = src.get("title", "Unbekannt")
                uri = src.get("uri", "")
                md += f"{i}. **{title}**"
                if uri:
                    md += f" – {uri}"
                md += "\n"
        else:
            md += "- NZZ Archiv\n- Google AI Search\n"
        
        md_file = self.output_dir / f"morticia-podcast-{self.date}.md"
        md_file.write_text(md, encoding="utf-8")
        return md_file
    
    def text_to_speech(self, script: str) -> Path:
        print("🔊 Erstelle MP3...")
        
        script_file = self.output_dir / f"script-{self.date}.txt"
        script_file.write_text(script, encoding="utf-8")
        
        mp3_file = self.output_dir / f"morticia-podcast-{self.date}.mp3"
        
        venv_edge = Path(__file__).parent / "venv" / "bin" / "edge-tts"
        edge_path = str(venv_edge) if venv_edge.exists() else "edge-tts"
        
        success, _, _ = self.run_command(f"test -x {edge_path}", timeout=5)
        
        if success or venv_edge.exists():
            voice = "de-DE-KatjaNeural"
            success, stdout, stderr = self.run_command(
                f'{edge_path} --voice "{voice}" --file "{script_file}" --write-media "{mp3_file}"',
                timeout=180
            )
            if success and mp3_file.exists():
                print(f"   ✅ MP3 erstellt: {mp3_file}")
                return mp3_file
        
        # Fallback
        venv_python = Path(__file__).parent / "venv" / "bin" / "python"
        if venv_python.exists():
            success, _, _ = self.run_command(
                f'{venv_python} -c "from gtts import gTTS; '
                f'tts = gTTS(text=open(\'{script_file}\').read(), lang=\'de\', slow=False); '
                f'tts.save(\'{mp3_file}\')"',
                timeout=120
            )
            if success:
                return mp3_file
        
        return script_file
    
    def publish_files(self, audio_file: Path, md_file: Path):
        print("🚀 Publiziere...")
        self.run_command(f"{MORTICIA_PUBLISH} {audio_file}", timeout=30)
        self.run_command(f"{MORTICIA_PUBLISH} {md_file}", timeout=30)
        print(f"   ✅ {BASE_URL}/{audio_file.name}")
        print(f"   ✅ {BASE_URL}/{md_file.name}")
    
    def generate(self):
        print(f"\n🎙️  Morticia Podcast – {self.date}\n")
        
        self.collect_news()
        self.generate_summaries()
        tts_script = self.generate_script()
        
        debug_file = self.output_dir / f"debug-{self.date}.txt"
        debug_file.write_text(tts_script, encoding="utf-8")
        print(f"\n📄 TTS-Skript: {len(tts_script.split())} Wörter")
        
        md_file = self.create_markdown(tts_script)
        audio_file = self.text_to_speech(tts_script)
        
        if self.publish:
            self.publish_files(audio_file, md_file)
        else:
            print(f"\n📂 Lokale Dateien:")
            print(f"   Audio: {audio_file}")
            print(f"   MD:    {md_file}")
        
        print("\n✅ Fertig!\n")


def main():
    parser = argparse.ArgumentParser(description="Generiert News-Podcast (15-20 Min.)")
    parser.add_argument("--date", help="Datum YYYY-MM-DD")
    parser.add_argument("--publish", "-p", action="store_true", help="Publizieren")
    
    args = parser.parse_args()
    
    generator = PodcastGenerator(date=args.date, publish=args.publish)
    generator.generate()


if __name__ == "__main__":
    main()
