#!/usr/bin/env python3
"""
morticia-publish - Tool zum Publizieren von Webseiten und Daten auf baettig.org

Verwendung:
    morticia-publish file1.html [file2.css ...]
    morticia-publish --sync-dir <lokales-verzeichnis>
    morticia-publish --list
    morticia-publish --delete <filename>

Die Dateien werden nach /var/www/html/morticia/ auf baettig.org kopiert
und sind unter https://baettig.org/morticia/<filename> verfügbar.
"""

import argparse
import os
import subprocess
import sys
from pathlib import Path

# Konfiguration
SSH_HOST = "baettig@baettig.org"
REMOTE_DIR = "/var/www/html/morticia"
BASE_URL = "https://baettig.org/morticia"

def run_ssh_command(command):
    """Führt einen SSH-Befehl auf dem Server aus."""
    full_command = ["ssh", SSH_HOST, command]
    try:
        result = subprocess.run(full_command, capture_output=True, text=True)
        return result.returncode == 0, result.stdout, result.stderr
    except Exception as e:
        return False, "", str(e)

def copy_file_to_server(local_path, remote_filename=None):
    """Kopiert eine Datei auf den Server."""
    local_path = Path(local_path)
    if not local_path.exists():
        print(f"❌ Fehler: Datei nicht gefunden: {local_path}")
        return False
    
    if remote_filename is None:
        remote_filename = local_path.name
    
    remote_path = f"{SSH_HOST}:{REMOTE_DIR}/{remote_filename}"
    
    try:
        subprocess.run(
            ["scp", str(local_path), remote_path],
            check=True,
            capture_output=True
        )
        url = f"{BASE_URL}/{remote_filename}"
        print(f"✅ {local_path.name} → {url}")
        return True
    except subprocess.CalledProcessError as e:
        print(f"❌ Fehler beim Kopieren von {local_path.name}: {e}")
        return False

def list_published_files():
    """Zeigt alle publizierten Dateien an."""
    success, stdout, stderr = run_ssh_command(f"ls -la {REMOTE_DIR}")
    if success:
        print(f"📂 Publizierte Dateien auf {BASE_URL}:")
        print("-" * 50)
        lines = stdout.strip().split('\n')[2:]  # Skip 'total' und . / ..
        for line in lines:
            parts = line.split()
            if len(parts) >= 9:
                size = parts[4]
                name = parts[8]
                url = f"{BASE_URL}/{name}"
                print(f"  {size:>10}  {url}")
    else:
        print(f"❌ Fehler beim Auflisten: {stderr}")

def delete_file(filename):
    """Löscht eine Datei vom Server."""
    success, _, stderr = run_ssh_command(f"rm {REMOTE_DIR}/{filename}")
    if success:
        print(f"🗑️  {filename} gelöscht")
        return True
    else:
        print(f"❌ Fehler beim Löschen von {filename}: {stderr}")
        return False

def sync_directory(local_dir):
    """Synchronisiert ein ganzes Verzeichnis mit dem Server (rekursiv)."""
    local_dir = Path(local_dir)
    if not local_dir.is_dir():
        print(f"❌ Fehler: Verzeichnis nicht gefunden: {local_dir}")
        return False
    
    # rsync verwenden für effiziente Synchronisation
    try:
        subprocess.run(
            [
                "rsync", "-avz", "--delete",
                str(local_dir) + "/",
                f"{SSH_HOST}:{REMOTE_DIR}/"
            ],
            check=True
        )
        print(f"✅ Verzeichnis {local_dir} synchronisiert")
        print(f"🌐 Alle Dateien verfügbar unter: {BASE_URL}/")
        return True
    except subprocess.CalledProcessError as e:
        print(f"❌ Fehler bei der Synchronisation: {e}")
        return False

def publish_text(content, filename):
    """Erstellt direkt eine Datei mit dem gegebenen Inhalt."""
    # Temporäre Datei erstellen
    temp_path = Path(f"/tmp/{filename}")
    temp_path.write_text(content, encoding='utf-8')
    success = copy_file_to_server(temp_path, filename)
    temp_path.unlink()  # Temporäre Datei löschen
    return success

def create_index_html(title="Morticia's Publizierter Inhalt", files=None):
    """Erstellt eine index.html mit Links zu allen Dateien."""
    if files is None:
        success, stdout, _ = run_ssh_command(f"ls {REMOTE_DIR}")
        if success:
            files = [f for f in stdout.strip().split('\n') if f and f != 'index.html']
        else:
            files = []
    
    file_list = "\n".join([
        f'    <li><a href="{f}">{f}</a></li>'
        for f in sorted(files)
    ])
    
    html = f"""<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <style>
        body {{
            font-family: system-ui, -apple-system, sans-serif;
            max-width: 800px;
            margin: 2rem auto;
            padding: 0 1rem;
            line-height: 1.6;
        }}
        h1 {{ color: #333; border-bottom: 2px solid #ddd; padding-bottom: 0.5rem; }}
        ul {{ list-style: none; padding: 0; }}
        li {{ margin: 0.5rem 0; padding: 0.5rem; background: #f5f5f5; border-radius: 4px; }}
        a {{ text-decoration: none; color: #0066cc; }}
        a:hover {{ text-decoration: underline; }}
        .meta {{ color: #666; font-size: 0.9rem; margin-top: 2rem; }}
    </style>
</head>
<body>
    <h1>{title}</h1>
    <ul>
{file_list}
    </ul>
    <div class="meta">
        <p>🔗 Basis-URL: {BASE_URL}/</p>
        <p>🕐 Zuletzt aktualisiert: {subprocess.check_output(['date', '+%Y-%m-%d %H:%M:%S']).decode().strip()}</p>
    </div>
</body>
</html>"""
    
    return publish_text(html, "index.html")

def main():
    parser = argparse.ArgumentParser(
        description="Publiziert Dateien auf baettig.org/morticia",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Beispiele:
  morticia-publish index.html style.css
  morticia-publish --list
  morticia-publish --sync-dir ./meine-webseite/
  morticia-publish --delete alte-datei.html
  morticia-publish --index "Meine Sammlung"
        """
    )
    
    parser.add_argument('files', nargs='*', help='Zu publizierende Dateien')
    parser.add_argument('--list', '-l', action='store_true', help='Liste alle publizierten Dateien')
    parser.add_argument('--delete', '-d', metavar='FILE', help='Lösche eine Datei vom Server')
    parser.add_argument('--sync-dir', '-s', metavar='DIR', help='Synchronisiere ein ganzes Verzeichnis')
    parser.add_argument('--index', '-i', nargs='?', const='Publizierte Dateien', metavar='TITLE', 
                        help='Erstelle index.html (optional mit Titel)')
    
    args = parser.parse_args()
    
    if args.list:
        list_published_files()
        return
    
    if args.delete:
        delete_file(args.delete)
        return
    
    if args.sync_dir:
        sync_directory(args.sync_dir)
        return
    
    if args.index is not None:
        create_index_html(args.index)
        print(f"✅ index.html erstellt: {BASE_URL}/")
        return
    
    if not args.files:
        parser.print_help()
        return
    
    # Dateien publizieren
    success_count = 0
    for file_path in args.files:
        if copy_file_to_server(file_path):
            success_count += 1
    
    print(f"\n📊 {success_count}/{len(args.files)} Dateien erfolgreich publiziert")
    print(f"🌐 Basis-URL: {BASE_URL}/")

if __name__ == "__main__":
    main()
